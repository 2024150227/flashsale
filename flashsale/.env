#进行环境变量配置
# 数据库配置
DATABASE_URL=mysql+mysqlconnector://flashsale:flashsale123@localhost:3306/flashsale

# Redis配置
REDIS_URL=redis://localhost:6379/0

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=flashsale_orders

# 应用配置
APP_NAME=FlashSale
APP_VERSION=1.0.0
DEBUG=True

# 限流配置
RATE_LIMIT=1000/minute

# 日志配置
LOG_LEVEL=INFO